# Auth.js / NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Google OAuth (same project as Gmail API)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated allowlist (leave empty to allow any Google account)
ALLOWED_EMAILS=you@galvor.com,colleague@galvor.com

# Google Sheets — share spreadsheet with service account email (Editor)
GOOGLE_SHEETS_SPREADSHEET_ID=1-nZCTRbeZCLgUPA91k37QlFHbL99sIKIdIUSB9tbmdc
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Outreach tracker (share with same service account — Editor)
GOOGLE_OUTREACH_TRACKER_SPREADSHEET_ID=13rGwhOjtNfYhjWDMZkIE_Iq3c6cY237g9JCKYYBGCl0
# Optional if tab name differs from default in lib/types.ts
# OUTREACH_TRACKER_TAB_NAME=Tracker

# External APIs (server-side only)
APIFY_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: background jobs while the site is closed (use cron-job.org every 5–15 min)
# Reply checks — use ?secret= (Vercel strips Authorization header):
#   GET https://your-app.vercel.app/api/cron/check-replies?secret=YOUR_CRON_SECRET
# CRM → Outbound Pipeline import (new rows only, deduped by email):
#   GET https://your-app.vercel.app/api/cron/sync-crm?secret=YOUR_CRON_SECRET
CRON_SECRET=
CRON_SENDER_EMAIL=
CRON_GMAIL_REFRESH_TOKEN=
