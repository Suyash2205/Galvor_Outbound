# Auth.js / NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Google OAuth (same project as Gmail API)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated allowlist (leave empty to allow any Google account)
ALLOWED_EMAILS=you@galvor.com,colleague@galvor.com

# Google Sheets — share spreadsheet with service account email (Editor)
GOOGLE_SHEETS_SPREADSHEET_ID=1-nZCTRbeZCLgUPA91k37QlFHbL99sIKIdIUSB9tbmdc
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# External APIs (server-side only)
APIFY_API_KEY=
ANTHROPIC_API_KEY=

# Optional: automated reply checks on Vercel (every 15 min)
CRON_SECRET=
CRON_SENDER_EMAIL=
CRON_GMAIL_REFRESH_TOKEN=
